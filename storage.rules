rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Template PDFs ────────────────────────────────────────────────────────
    // Stored at: templates/{boardId}/{templateId}.pdf
    // Any authenticated user can read (download) a template.
    // Write (upload/delete) is restricted to authenticated users at the app
    // level — board-admin enforcement is handled in the Flutter app and
    // Firestore rules. Tighten here once custom auth claims are in place.

    match /templates/{boardId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.contentType.matches('application/pdf')
                   && request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // ── Completed / stamped PDFs ─────────────────────────────────────────────
    // Stored at: completed/{agentId}/{transactionId}/{filledFormId}.pdf
    // Strictly per-agent: only the owning agent can read or write.

    match /completed/{agentId}/{transactionId}/{fileName} {
      allow read, write: if request.auth != null
                         && request.auth.uid == agentId;
    }

    // ── Remote signing ───────────────────────────────────────────────────────
    // Stored at: signing/{token}/signed.pdf
    // Writable by any authenticated user (including anonymous — the signer).
    // Readable publicly so the agent and signer can download the signed PDF.

    match /signing/{token}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.contentType.matches('application/pdf')
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
